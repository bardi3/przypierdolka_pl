# Blokada wykonywania skryptów w katalogu uploadów
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Deny from all
</IfModule>

Options -ExecCGI -Indexes
RemoveHandler .php .phtml .php3 .php4 .php5 .php7 .phps
RemoveType .php .phtml .php3 .php4 .php5 .php7 .phps

# Zezwól na pobieranie obrazków
<FilesMatch "\.(?i:jpe?g|png|gif|webp|svg)$">
    <IfModule mod_authz_core.c>
        Require all granted
    </IfModule>
    <IfModule !mod_authz_core.c>
        Allow from all
    </IfModule>
</FilesMatch>

# Cache obrazków użytkownika (URL z ?v=filemtime — długi TTL bezpieczny)
<IfModule mod_headers.c>
    <FilesMatch "\.(?i:jpe?g|png|gif|webp|svg)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>
