# przypierdolka.pl - konfiguracja Apache dla katalogu public/

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Jeśli aplikacja działa w podkatalogu, ustaw RewriteBase /
    # RewriteBase /

    # Nie przepisuj istniejących plików i katalogów (assety, uploady)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Wszystko inne -> front controller
    RewriteRule ^ index.php [L]
</IfModule>

# Bezpieczeństwo: blokada dostępu do plików ukrytych i wrażliwych
<FilesMatch "(^\.|\.(htaccess|ini|log|sh|sql|env)$)">
    Require all denied
</FilesMatch>

# Nie listuj katalogów
Options -Indexes

# Kompresja
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/css application/javascript application/json image/svg+xml
</IfModule>

# Cache statycznych assetów
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Nagłówki bezpieczeństwa
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
