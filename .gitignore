/public/assets/uploads/stories/*
!/public/assets/uploads/stories/.gitkeep
/public/assets/uploads/generated/*
!/public/assets/uploads/generated/.gitkeep
/public/assets/uploads/avatars/*
!/public/assets/uploads/avatars/.gitkeep

